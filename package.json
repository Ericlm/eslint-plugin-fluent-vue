{
  "name": "eslint-plugin-fluent-vue",
  "version": "0.0.1",
  "description": "ESLint plugin for Fluent-Vue integration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "peerDependencies": {
    "eslint": ">=10.0.0"
  },
  "dependencies": {
    "vue-eslint-parser": "^10.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --fix"
  }
}
