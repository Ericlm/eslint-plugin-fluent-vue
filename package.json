{
  "name": "eslint-plugin-fluent-vue",
  "version": "0.0.1",
  "description": "ESLint plugin for Fluent-Vue integration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "peerDependencies": {
    "eslint": ">=10.0.0"
  },
  "dependencies": {
    "@changesets/cli": "^2.30.0",
    "vue-eslint-parser": "^10.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.5.2",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "eslint-plugin-eslint-plugin": "^7.3.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "tsc",
    "changeset": "changeset",
    "format": "prettier --write .",
    "lint": "eslint .",
    "prepare": "husky install",
    "test": "vitest",
    "type-check": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --fix"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "semi": false
  }
}
